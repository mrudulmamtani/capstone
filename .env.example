# ---------------------------------------------------------------------------
# VISION-SOP environment configuration
# Copy this file to `.env` and fill in values before `docker compose up`.
# ---------------------------------------------------------------------------

# Core
APP_ENV=development
APP_NAME=vision-sop
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string
APP_LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://vision:vision@postgres:5432/vision_sop
DATABASE_POOL_SIZE=10

# Redis (WebSocket fan-out + job queue)
REDIS_URL=redis://redis:6379/0

# LLM provider: openai | anthropic | ollama | stub
LLM_PROVIDER=stub
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Vision pipeline
YOLO_MODEL=yolov8n-pose.pt
YOLO_DETECT_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.4
PIPELINE_TARGET_FPS=10
PIPELINE_MAX_WORKERS=2

# Privacy
PRIVACY_FACE_BLUR=1
PRIVACY_STORE_RAW_CLIPS=0
PRIVACY_RETENTION_DAYS=30

# Paths (inside container / local checkout)
DATA_DIR=/app/data
VIDEO_DIR=/app/data/videos
MODEL_DIR=/app/data/models
SOP_DIR=/app/data/generated_sops
HEATMAP_DIR=/app/data/heatmaps

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
